{
  "name": "fada-lustre-api",
  "version": "1.0.0",
  "description": "Fada Lustre cleaning services backend API",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsoa spec && tsoa routes && tsc -p tsconfig.build.json",
    "start": "node ./dist/index.js",
    "dev": "tsoa spec && tsoa routes && tsx watch ./src/index.ts",
    "tsoa:gen": "tsoa spec && tsoa routes",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node ./sql/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-fileupload": "^1.5.1",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.0",
    "@types/express-fileupload": "^1.5.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.10.2",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
