# Server
PORT=3000

# PostgreSQL (Neon)
DB_USER=neondb_owner
DB_HOST=your-neon-host.neon.tech
DB_DB=neondb
DB_PASSWORD=your_password_here
DB_PORT=5432
DB_SSL=true

# Auth
JWT_SECRET=generate_a_256_bit_secret_here
JWT_REFRESH_SECRET=generate_another_256_bit_secret_here

# Resend (email delivery)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Fada Lustre <noreply@fadalustre.com>

# Cloudflare R2 (image uploads)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=fada-lustre-staging
R2_PUBLIC_URL=https://your_account_id.r2.cloudflarestorage.com

# Security
ENCRYPTION_KEY=generate_a_256_bit_key_here

# CORS
ALLOWED_ORIGINS=http://localhost:3000
